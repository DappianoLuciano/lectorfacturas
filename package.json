{
  "name": "carga-facturas",
  "version": "2.0.1",
  "description": "Cargador de facturas de proveedores para óptica",
  "main": "main/main.js",
  "scripts": {
    "dev:renderer": "npm --prefix renderer run dev",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "concurrently -k \"npm run dev:renderer\" \"npm run dev:electron\"",
    "build:renderer": "npm --prefix renderer run build",
    "build": "npm run build:renderer && electron-builder",
    "dist": "npm run build:renderer && electron-builder --win",
    "release": "npm run build:renderer && electron-builder --win --publish always"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.8.3",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.optica.cargafacturas",
    "productName": "Carga Facturas",
    "asar": false,
    "files": [
      "main/**/*",
      "renderer/dist/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Carga Facturas"
    },
    "directories": {
      "output": "dist-electron"
    },
    "publish": {
      "provider": "github",
      "owner": "DappianoLuciano",
      "repo": "lectorfacturas",
      "releaseType": "release"
    }
  }
}
